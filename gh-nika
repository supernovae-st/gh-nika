#!/usr/bin/env bash
# gh-nika — GitHub CLI extension for the Nika workflow engine (nika.sh).
#
#   gh nika check flow.nika.yaml     # static audit before a token is spent
#   gh nika run   flow.nika.yaml     # execute with a hash-chained trace
#
# Uses the `nika` already on PATH when present; otherwise fetches the
# latest verified release binary once (SHA256SUMS-checked) into
# ${XDG_DATA_HOME:-~/.local/share}/gh-nika and runs it from there.
set -euo pipefail

if command -v nika >/dev/null 2>&1; then
  exec nika "$@"
fi

REPO="supernovae-st/nika"
DIR="${GH_NIKA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/gh-nika}"
BIN="$DIR/nika"

# GH_NIKA_REFRESH=1 discards the cached binary and re-fetches the latest release.
if [ "${GH_NIKA_REFRESH:-0}" = "1" ]; then
  rm -f "$BIN"
fi

if [ ! -x "$BIN" ]; then
  case "$(uname -s)" in
    Darwin) plat=macos ;;
    Linux) plat=linux ;;
    *)
      echo "gh-nika: unsupported OS $(uname -s) — nika ships macOS + Linux binaries" >&2
      exit 1
      ;;
  esac
  case "$(uname -m)" in
    x86_64 | amd64) arch=x64 ;;
    arm64 | aarch64) arch=arm64 ;;
    *)
      echo "gh-nika: unsupported arch $(uname -m)" >&2
      exit 1
      ;;
  esac

  tag="$(gh release view --repo "$REPO" --json tagName --jq .tagName)"
  ver="${tag#v}"
  asset="nika-${plat}-${arch}-${ver}.tar.gz"

  tmp="$(mktemp -d)"
  trap 'rm -rf "$tmp"' EXIT
  echo "gh-nika: fetching nika ${tag} (${plat}-${arch}, checksum-verified)…" >&2
  gh release download "$tag" --repo "$REPO" --pattern "$asset" --dir "$tmp"
  gh release download "$tag" --repo "$REPO" --pattern "SHA256SUMS" --dir "$tmp"

  (
    cd "$tmp"
    if ! grep -q "  ${asset}\$" SHA256SUMS; then
      echo "gh-nika: ${asset} not listed in the release SHA256SUMS — refusing to install" >&2
      exit 1
    fi
    if command -v sha256sum >/dev/null 2>&1; then
      grep "  ${asset}\$" SHA256SUMS | sha256sum -c - >&2
    else
      grep "  ${asset}\$" SHA256SUMS | shasum -a 256 -c - >&2
    fi
  )

  mkdir -p "$DIR"
  tar -xzf "$tmp/$asset" -C "$DIR"
  chmod +x "$BIN"
fi

exec "$BIN" "$@"
